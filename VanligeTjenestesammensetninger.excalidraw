      "updated": 1775806516588,
      "link": null,
      "locked": false,
      "text": "Vi trenger ikke å vite hvor personen bor, men bare hva de heter.\nTelefonnummeret er grensesnittet. Hvis noen endrer nummeret,\nså vil du ikke nå samme person.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Vi trenger ikke å vite hvor personen bor, men bare hva de heter.\nTelefonnummeret er grensesnittet. Hvis noen endrer nummeret,\nså vil du ikke nå samme person.",
      "autoResize": true,
      "lineHeight": 1.25
    },
